{
  "expo": {
    "name": "ClearSnap",
    "slug": "clearsnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.clearsnap.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "ClearSnap needs access to your photos.",
          "savePhotosPermission": "Allow ClearSnap to manage photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}
